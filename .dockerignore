# VCS
.git
.gitignore

# ROS2 build artifacts (rebuilt inside the container)
build/
install/
log/

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# Editors / OS
.vscode/
.idea/
*.swp
.DS_Store

# Docs / misc (not needed in build context)
*.md
!docker/README.md

# Secrets — never ship these into an image
.env
*.pem
*.key
