<?xml version="1.0"?>
<robot name="guide_robot" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- Параметры робота -->
  <xacro:property name="wheel_radius" value="0.075"/>
  <xacro:property name="wheel_base"   value="0.338"/>
  <xacro:property name="wheel_width"  value="0.05"/>
  <xacro:property name="sonar_height" value="0.15"/>

  <!-- ═══════════════════════════════════════════════════════
       BASE LINK — центр робота (между колёсами, на уровне пола)
       ═══════════════════════════════════════════════════════ -->
  <link name="base_link">
    <visual>
      <geometry>
        <!-- Примерные габариты корпуса: 55×55×30 см -->
        <box size="0.55 0.55 0.30"/>
      </geometry>
      <!-- Смещаем визуал вверх, чтобы низ корпуса был на уровне base_link -->
      <origin xyz="-0.18 0 0.15" rpy="0 0 0"/>
      <material name="grey">
        <color rgba="0.5 0.5 0.5 1.0"/>
      </material>
    </visual>
  </link>

  <!-- ═══════════════════════════════════════════════════════
       МАКРОС КОЛЕСА
       Параметры:
         name — "left" или "right"
         x    — смещение вдоль X (вперёд/назад)
         y    — смещение вдоль Y (влево/вправо)
       ═══════════════════════════════════════════════════════ -->
  <xacro:macro name="wheel" params="name x y">

    <link name="${name}_wheel_link">
      <visual>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <!-- Поворачиваем цилиндр: по умолчанию его ось Z смотрит вверх,
             нам нужна ось Y (горизонтально) → поворот на 90° вокруг X -->
        <origin xyz="0 0 0" rpy="1.5708 0 0"/>
        <material name="black">
          <color rgba="0.1 0.1 0.1 1.0"/>
        </material>
      </visual>
    </link>

    <joint name="${name}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child  link="${name}_wheel_link"/>
      <!-- Позиция колеса относительно base_link.
           z = -wheel_radius: колесо касается пола (base_link на уровне пола) -->
      <origin xyz="${x} ${y} ${-wheel_radius}" rpy="0 0 0"/>
      <!-- Колесо вращается вокруг оси Y (общая для обоих колёс) -->
      <axis xyz="0 1 0"/>
    </joint>

  </xacro:macro>

  <!-- ═══════════════════════════════════════════════════════
       МАКРОС СОНАРА
       Параметры:
         name — номер сонара (1,2,4,5,6,8,9)
         x    — смещение вдоль X от центра робота (м)
         y    — смещение вдоль Y от центра робота (м)
         yaw  — угол ориентации сонара (рад)
       ═══════════════════════════════════════════════════════ -->
  <xacro:macro name="sonar_sensor" params="name x y yaw">

    <link name="sonar_${name}_link">
      <visual>
        <geometry>
          <box size="0.04 0.04 0.03"/>
        </geometry>
        <material name="blue">
          <color rgba="0.0 0.4 0.8 1.0"/>
        </material>
      </visual>
    </link>

    <joint name="sonar_${name}_joint" type="fixed">
      <parent link="base_link"/>
      <child  link="sonar_${name}_link"/>
      <!-- Сонары крепятся на высоте sonar_height от base_link -->
      <origin xyz="${x} ${y} ${sonar_height}" rpy="0 0 ${yaw}"/>
    </joint>

  </xacro:macro>

  <!-- ═══════════════════════════════════════════════════════
       КОЛЁСА
       Левое: y = +wheel_base/2 (сторона +Y = лево)
       Правое: y = -wheel_base/2 (сторона -Y = право)
       ═══════════════════════════════════════════════════════ -->
  <xacro:wheel name="left"  x="0" y="${wheel_base / 2}"/>
  <xacro:wheel name="right" x="0" y="${-wheel_base / 2}"/>

  <!-- ═══════════════════════════════════════════════════════
       СОНАРЫ (7 штук)
       Координаты из RobotSetting.xml → <installPosition>
       Углы: <direction> в градусах → радианы
       ═══════════════════════════════════════════════════════ -->

  <!-- Два спереди -->
  <xacro:sonar_sensor name="1" x="0.061107"  y="0.215993"  yaw="0.7336"/>
  <xacro:sonar_sensor name="9" x="0.061107"  y="-0.215993" yaw="-0.7336"/>

  <!-- Четыре по бокам -->
  <!-- Левый борт -->
  <xacro:sonar_sensor name="2" x="-0.040039" y="0.260183"  yaw="1.5708"/>
  <xacro:sonar_sensor name="4" x="-0.393220" y="0.132040"  yaw="2.4091"/>
  <!-- Правый борт -->
  <xacro:sonar_sensor name="8" x="-0.040039" y="-0.260183" yaw="-1.5708"/>
  <xacro:sonar_sensor name="6" x="-0.393220" y="-0.132040" yaw="-2.4091"/>

  <!-- Один сзади -->
  <xacro:sonar_sensor name="5" x="-0.435289" y="0.0"       yaw="3.1416"/>

</robot>
