<?xml version="1.0"?>
<!-- =========================================================================
     ros2_control interface for Guide robot.

     Three hardware backends, priority top to bottom:
       use_sim=true           -> Gazebo Classic (gazebo_ros2_control)
       use_mock_hardware=true -> mock_components stub for stack testing
       otherwise              -> real Dynamixel driver

     IMPORTANT: comments MUST stay ASCII-only (see note in guide_robot.urdf.xacro).
     ========================================================================= -->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:arg name="use_sim"           default="false"/>
  <xacro:arg name="use_mock_hardware" default="false"/>

  <ros2_control name="GuideRobotSystem" type="system">

    <hardware>
      <xacro:if value="$(arg use_sim)">
        <!-- Gazebo Classic: simulated hardware via gazebo_ros2_control.
             Drives the same velocity interfaces as the real base. -->
        <plugin>gazebo_ros2_control/GazeboSystem</plugin>
      </xacro:if>
      <xacro:unless value="$(arg use_sim)">
        <xacro:if value="$(arg use_mock_hardware)">
          <!-- Stub for running the stack without real hardware -->
          <plugin>mock_components/GenericSystem</plugin>
          <param name="calculate_dynamics">true</param>
        </xacro:if>
        <xacro:unless value="$(arg use_mock_hardware)">
          <!-- Real Dynamixel base driver -->
          <plugin>guide_robot_hardware/GuideRobotSystem</plugin>
          <param name="serial_port">COM7</param>            <!-- TO-DO -->
          <param name="baud_rate">115200</param>
          <param name="left_wheel_id">46</param>            <!-- 0x2E -->
          <param name="right_wheel_id">47</param>           <!-- 0x2F -->
          <param name="ticks_per_rev">262144</param>        <!-- 512*8*64 -->
          <param name="left_sign">-1</param>                <!-- LeftReverse -->
          <param name="right_sign">1</param>                <!-- RightReverse -->
          <param name="swap_drives">1</param>               <!-- FURO_SWAP_DRIVES -->
          <param name="speed_coefficient">0.014</param>     <!-- m/s -->
          <param name="cmd_timeout">0.3</param>             <!-- watchdog, sec -->
        </xacro:unless>
      </xacro:unless>
    </hardware>

    <!-- Left wheel -->
    <joint name="left_wheel_joint">
      <command_interface name="velocity">
        <param name="min">-6.98</param>   <!-- rad/s -->
        <param name="max">6.98</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <!-- Right wheel -->
    <joint name="right_wheel_joint">
      <command_interface name="velocity">
        <param name="min">-6.98</param>
        <param name="max">6.98</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

  </ros2_control>

</robot>
