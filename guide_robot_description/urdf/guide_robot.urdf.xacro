<?xml version="1.0"?>
<!-- =========================================================================
     Guide robot - main robot description.
     Geometry from RobotSetting.xml. Meshes are replaced by primitives for now
     (body cylinder + wheel cylinders) - enough for costmap and TF.
     Lidar mounts and connecting profile use real meshes.

     Rear casters are a real part of the robot (top-heavy chassis support).

     IMPORTANT: comments MUST stay ASCII-only. Non-ASCII characters break
     gazebo_ros2_control, which passes robot_description as a CLI parameter
     and truncates the buffer mid multi-byte sequence.
     ========================================================================= -->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="guide_robot">

  <!-- Simulation flag: enables gazebo plugins and switches hardware backend -->
  <xacro:arg name="use_sim" default="false"/>

  <!-- ===================== Parameters (from robot_params.yaml) =========== -->
  <xacro:property name="wheel_separation" value="0.338"/>   <!-- WheelBase -->
  <xacro:property name="wheel_radius"     value="0.075"/>    <!-- WheelDiameter/2 -->
  <xacro:property name="wheel_width"      value="0.048"/>    <!-- WheelWidth -->

  <!-- Body dimensions - rough estimate of top-heavy chassis -->
  <xacro:property name="body_radius" value="0.31"/>
  <xacro:property name="body_height" value="1.62"/>
  <xacro:property name="body_z"      value="0.885"/>         <!-- body center Z -->

  <!-- Ground clearance: wheel axle height above floor = wheel_radius -->
  <xacro:property name="base_z" value="${wheel_radius}"/>

  <!-- Rear casters (real support) -->
  <xacro:property name="caster_radius" value="${base_z}"/>   <!-- = wheel_radius, keeps robot level -->
  <xacro:property name="caster_x"      value="-0.3"/>       <!-- behind base center, ~20 cm -->
  <xacro:property name="caster_y"      value="0.12"/>        <!-- lateral spacing -->

  <!-- Lidar mounts + connecting bar (2020 extrusion) -->
  <xacro:property name="lidar_mount_mesh" value="package://guide_robot_description/meshes/lidars_mount.stl"/>
  <xacro:property name="lidar_bar_mesh"   value="package://guide_robot_description/meshes/al_profile.stl"/>
  <!-- TO-DO: if meshes were exported from CAD in mm, scale 0.001 is required.
       Check in RViz: huge or tiny model means wrong scale. -->
  <xacro:property name="mesh_scale" value="0.001 0.001 0.001"/>
  <xacro:property name="lidar_y_offset" value="0.258"/>      <!-- from laser_joint_left/right -->
  <xacro:property name="lidar_z" value="0.4"/>

  <!-- ===================== RViz materials =============================== -->
  <material name="grey"><color rgba="0.4 0.4 0.45 1.0"/></material>
  <material name="dark"><color rgba="0.15 0.15 0.15 1.0"/></material>
  <material name="blue"><color rgba="0.1 0.4 0.8 0.6"/></material>

  <!-- ===================== base_footprint / base_link =================== -->
  <link name="base_footprint"/>

  <link name="base_link">
    <visual>
      <origin xyz="-0.12 0 ${body_z - base_z}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${body_radius}" length="${body_height}"/>
      </geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <origin xyz="-0.12 0 ${body_z - base_z}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${body_radius}" length="${body_height}"/>
      </geometry>
    </collision>
    <inertial>
      <!-- Mass and inertia are rough estimates, TO-DO -->
      <mass value="62.0"/>
      <origin xyz="-0.12 0 0.3" rpy="0 0 0"/>
      <inertia ixx="5.0" ixy="0.0" ixz="0.0" iyy="5.0" iyz="0.0" izz="2.0"/>
    </inertial>
  </link>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child  link="base_link"/>
    <origin xyz="0 0 ${base_z}" rpy="0 0 0"/>
  </joint>

  <!-- ===================== Wheel macro ================================== -->
  <xacro:macro name="wheel" params="prefix y_offset">
    <link name="${prefix}_wheel_link">
      <visual>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <material name="dark"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="1.0"/>
        <inertia ixx="0.002" ixy="0" ixz="0" iyy="0.002" iyz="0" izz="0.003"/>
      </inertial>
    </link>

    <joint name="${prefix}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child  link="${prefix}_wheel_link"/>
      <origin xyz="0 ${y_offset} 0" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
    </joint>
  </xacro:macro>

  <xacro:wheel prefix="left"  y_offset="${ wheel_separation/2}"/>
  <xacro:wheel prefix="right" y_offset="${-wheel_separation/2}"/>

  <!-- ===================== Caster macro (rear support) ================== -->
  <!-- Real robot has two rear supports. Modeled as spheres:
       fixed joint + zero friction in Gazebo (see guide_robot.gazebo.xacro).
       Radius = base_z, center in wheel axle plane -> sphere bottom touches
       the floor, robot rests level on 4 points. diff_drive_controller ignores
       them (odometry uses driven wheels only). -->
  <xacro:macro name="caster" params="prefix y_offset">
    <link name="${prefix}_caster_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <sphere radius="${caster_radius}"/>
        </geometry>
        <material name="dark"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <sphere radius="${caster_radius}"/>
        </geometry>
      </collision>
      <inertial>
        <!-- Sphere inertia: I = 2/5 * m * r^2 = 2/5 * 0.2 * 0.075^2 -->
        <mass value="0.2"/>
        <inertia ixx="0.00045" ixy="0" ixz="0" iyy="0.00045" iyz="0" izz="0.00045"/>
      </inertial>
    </link>

    <joint name="${prefix}_caster_joint" type="fixed">
      <parent link="base_link"/>
      <child  link="${prefix}_caster_link"/>
      <origin xyz="${caster_x} ${y_offset} 0" rpy="0 0 0"/>
    </joint>
  </xacro:macro>

  <xacro:caster prefix="left"  y_offset="${ caster_y}"/>
  <xacro:caster prefix="right" y_offset="${-caster_y}"/>

  <!-- ===================== Sonar (parking sensor) macro ================= -->
  <xacro:macro name="sonar_sensor" params="id x y yaw">
      <link name="sonar_sensor_${id}">
        <visual>
          <geometry><box size="0.01 0.02 0.01"/></geometry>
          <material name="dark"/>
        </visual>
        <inertial>
          <mass value="0.01"/>
          <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
        </inertial>
      </link>
      <joint name="sonar_sensor_${id}_joint" type="fixed">
        <parent link="base_link"/>
        <child  link="sonar_sensor_${id}"/>
        <origin xyz="${x} ${y} 0.2" rpy="0 0 ${radians(yaw)}"/>
      </joint>
    </xacro:macro>

  <!-- Two front -->
  <xacro:sonar_sensor id="1" x="0.15"  y="0.10"  yaw="0"/>
  <xacro:sonar_sensor id="9" x="0.15"  y="-0.10" yaw="0"/>
  <!-- Left side -->
  <xacro:sonar_sensor id="2" x="-0.040039" y="0.260183"  yaw="90"/>
  <xacro:sonar_sensor id="4" x="-0.393220" y="0.132040"  yaw="138.03"/>
  <!-- Right side -->
  <xacro:sonar_sensor id="8" x="-0.040039" y="-0.260183" yaw="-90"/>
  <xacro:sonar_sensor id="6" x="-0.393220" y="-0.132040" yaw="-138.03"/>
  <!-- One rear -->
  <xacro:sonar_sensor id="5" x="-0.435289" y="0.0"       yaw="180"/>

  <!-- ===================== Lidar mounts + bar ========================== -->
  <!-- lidars_mount.stl is the mounting plate under each lidar.
       Laser frames attach to these links instead of base_link directly. -->
  <xacro:macro name="lidar_mount" params="prefix y_offset xyz_mesh:='0 0 0' rpy_mesh:='0 0 0'">
    <link name="${prefix}_lidar_mount_link">
      <visual>
        <origin xyz="${xyz_mesh}" rpy="${rpy_mesh}"/>
        <geometry>
          <mesh filename="${lidar_mount_mesh}" scale="${mesh_scale}"/>
        </geometry>
        <material name="dark"/>
      </visual>
      <collision>
        <!-- Simplified box instead of full mesh - cheaper for costmap -->
        <origin xyz="0 0 0.02" rpy="0 0 0"/>
        <geometry>
          <box size="0.06 0.06 0.05"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.05"/>
        <inertia ixx="0.00002" ixy="0" ixz="0" iyy="0.00002" iyz="0" izz="0.00002"/>
      </inertial>
    </link>

    <joint name="${prefix}_lidar_mount_joint" type="fixed">
      <parent link="base_link"/>
      <child  link="${prefix}_lidar_mount_link"/>
      <origin xyz="0.075 ${y_offset} ${lidar_z}" rpy="0 0 0"/>
    </joint>
  </xacro:macro>

  <xacro:lidar_mount prefix="left"  y_offset="${ lidar_y_offset}"/>
  <!-- TO-DO: right mount is probably mirrored. If the mesh faces the wrong way
       in RViz, adjust rpy_mesh (usually 180 deg around Z or X). -->
  <xacro:lidar_mount prefix="right" y_offset="${-lidar_y_offset}" rpy_mesh="0 0 0"/>

  <!-- Connecting profile between the two mounts -->
  <link name="lidar_bar_link">
    <visual>
      <origin xyz="0 -0.288 0.02" rpy="${radians(-90)} ${radians(11)} 0"/>
      <geometry>
        <mesh filename="${lidar_bar_mesh}" scale="0.001 0.001 0.0115"/>
      </geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <!-- TO-DO: verify length and cross-section against real 2020 bounding box -->
        <box size="0.02 ${lidar_y_offset*2} 0.02"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="lidar_bar_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="lidar_bar_link"/>
    <origin xyz="0.077 0.0 ${lidar_z}" rpy="0 0 0"/>
  </joint>

  <!-- ===================== LiDAR frames ================================ -->
  <!-- Laser frames sit on the mounts, not on base_link.
       z-offset 0.03 is a placeholder for lidar body height, TO-DO verify. -->
  <link name="laser_frame_left"/>
  <joint name="laser_joint_left" type="fixed">
    <parent link="left_lidar_mount_link"/>
    <child  link="laser_frame_left"/>
    <origin xyz="0 0 0.03" rpy="${pi} 0 0"/>
  </joint>

  <link name="laser_frame_right"/>
  <joint name="laser_joint_right" type="fixed">
    <parent link="right_lidar_mount_link"/>
    <child  link="laser_frame_right"/>
    <origin xyz="0 0 0.03" rpy="${pi} 0 0"/>
  </joint>

  <!-- ===================== IMU ========================================= -->
  <!-- TO-DO: verify real IMU position -->
  <link name="imu_link"/>
  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="imu_link"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
  </joint>

  <!-- ===================== ros2_control interface ====================== -->
  <xacro:include filename="$(find guide_robot_description)/urdf/guide_robot.ros2_control.xacro"/>

  <!-- ===================== Gazebo (simulation only) ==================== -->
  <xacro:if value="$(arg use_sim)">
    <xacro:include filename="$(find guide_robot_description)/urdf/guide_robot.gazebo.xacro"/>
  </xacro:if>

</robot>
